{
        // Use IntelliSense to learn about possible attributes.
        // Hover to view descriptions of existing attributes.
        // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python Debugger: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal"
        },
        {
            "name": "Pytest: Current File",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": [
                "${file}"
            ],
            "console": "integratedTerminal",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src"
            },
            "justMyCode": true
        },
        {
            "name": "Pytest: All",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": [
                "."
            ],
            "console": "integratedTerminal",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src"
            },
            "justMyCode": true
        },
        {
            "name": "Python: scripts/fetch_models",
            "type": "debugpy",
            "request": "launch",
            "module": "scripts.fetch_models",
            "args": [
            ],
            "cwd": "${workspaceFolder}",
            "env": {
                "PYTHONPATH": "${workspaceFolder}",
            },
            "justMyCode": true
        },
        {
            "name": "Python: scripts/setup_dev_repo",
            "type": "debugpy",
            "request": "launch",
            "module": "scripts.setup_dev_repo",
            "args": [
                "--repo", "_tmp/repo",
                "--agent-config", "templates/project-calculator/.agent",
            ],
            "cwd": "${workspaceFolder}",
            "env": {
                "PYTHONPATH": "${workspaceFolder}",
            },
            "justMyCode": true
        },
        {
            "name": "Python: scripts/snapshot_tmp",
            "type": "debugpy",
            "request": "launch",
            "module": "scripts.snapshot_tmp",
            "args": [
            ],
            "cwd": "${workspaceFolder}",
            "env": {
                "PYTHONPATH": "${workspaceFolder}",
            },
            "justMyCode": true
        },
        {
            "name": "Blondie: Run Agent (_tmp/repo)",
            "type": "debugpy",
            "request": "launch",
            "module": "src.agent.loop",
            "args": [
                "${workspaceFolder}/_tmp/repo",
                "--journal-dir", "${workspaceFolder}/_tmp/logs",
            ],
            "cwd": "${workspaceFolder}",
            "env": {
                "PYTHONPATH": "${workspaceFolder}",
                "MSYSTEM": "MSYS",
                "VSCODE_SETTING": "launch.json",
            },
            "justMyCode": true
        }
    ]
}